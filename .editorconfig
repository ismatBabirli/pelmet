# https://editorconfig.org — keeps whitespace consistent across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown uses trailing whitespace for hard line breaks.
[*.md]
trim_trailing_whitespace = false

# YAML / JSON in this repo are 2-space (issue templates, asset catalogs).
[*.{yml,yaml,json}]
indent_size = 2
